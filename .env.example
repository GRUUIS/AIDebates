############################################################
# LLM provider (pick ONE): Vertex AI Express Mode OR OpenRouter
#
# Precedence in code (`lib/llm.ts`):
# 1) Vertex (when `VERTEX_USE_EXPRESS_MODE=true` and `GOOGLE_API_KEY` is set)
# 2) OpenRouter (when `OPENROUTER_API_KEY` is set)
# 3) OpenAI (when `OPENAI_API_KEY` is set)
############################################################

############################
# Option A: Vertex AI Express
############################
# Enable Vertex by setting this to true AND providing GOOGLE_API_KEY.
VERTEX_USE_EXPRESS_MODE=true
GOOGLE_API_KEY=your_vertex_express_api_key_here

# Chat (and multimodal) models
VERTEX_MODEL=gemini-2.5-flash
VERTEX_FALLBACK_MODELS=gemini-2.5-pro
VERTEX_MULTIMODAL_MODEL=gemini-2.5-flash

# Embeddings
VERTEX_EMBEDDING_MODEL=gemini-embedding-001

# Optional follow-up phases:
# VERTEX_SPEECH_MODEL=gemini-2.5-flash-preview-tts
# VERTEX_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

########################
# Option B: OpenRouter
########################
# To use OpenRouter instead of Vertex, either:
# - set `VERTEX_USE_EXPRESS_MODE=false`, OR
# - keep it true but remove GOOGLE_API_KEY.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Chat model (example)
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# Optional per-capability overrides:
# OPENROUTER_MULTIMODAL_MODEL=openai/gpt-4o-mini
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENROUTER_SPEECH_MODEL=openai/gpt-4o-mini-tts
# OPENROUTER_IMAGE_MODEL=openai/gpt-image-1

########################
# Search (Tavily)
########################
SEARCH_API_KEY=your_search_api_key_here
